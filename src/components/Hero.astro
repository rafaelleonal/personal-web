---
import { i18n } from '../data/i18n';

const es = i18n.es.hero;
const en = i18n.en.hero;
---

<section
  id="about"
  class="min-h-screen flex flex-col justify-center section-x hero-pt hero-pb section-max relative"
>
  <!-- Greeting -->
  <div data-reveal class="mb-4">
    <p class="font-mono text-sm text-accent tracking-wide font-medium">
      <span class="lang-es">{es.greeting}</span>
      <span class="lang-en lang-hidden">{en.greeting}</span>
    </p>
  </div>

  <!-- Name -->
  <div data-reveal data-reveal-delay="0.06" class="mb-2">
    <h1
      class="font-display font-bold text-hero tracking-[-0.045em] leading-none text-ink"
    >
      Rafael León
    </h1>
  </div>

  <!-- Role -->
  <div data-reveal data-reveal-delay="0.12" class="mb-7">
    <h2
      class="font-display font-light text-hero-role tracking-[-0.03em] leading-tight text-ink2"
    >
      <span class="lang-es">{es.role}</span>
      <span class="lang-en lang-hidden">{en.role}</span>
    </h2>
  </div>

  <!-- Bio -->
  <div data-reveal data-reveal-delay="0.18" class="mb-9">
    <p class="text-[17px] leading-[1.8] text-ink2 max-w-[540px]">
      <span class="lang-es">{es.bio}</span>
      <span class="lang-en lang-hidden">{en.bio}</span>
    </p>
  </div>

  <!-- CTA links -->
  <div data-reveal data-reveal-delay="0.24" class="hero-actions flex items-center gap-5 flex-wrap">
    <a
      href="mailto:rafaleonalfaro@gmail.com"
      data-magnetic
      class="inline-flex items-center px-7 py-3 bg-accent text-white rounded-[10px] font-semibold text-sm magnetic"
    >
      <span class="lang-es">{es.cta}</span>
      <span class="lang-en lang-hidden">{en.cta}</span>
    </a>

    <div class="flex gap-4 text-sm text-ink2">
      <a
        href="https://www.linkedin.com/in/rafael-le%C3%B3n-alfaro-97617b168/"
        target="_blank"
        rel="noopener noreferrer"
        class="border-b border-edge hover:text-accent transition-colors duration-200 pb-px"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/rafaelleonal"
        target="_blank"
        rel="noopener noreferrer"
        class="border-b border-edge hover:text-accent transition-colors duration-200 pb-px"
      >
        GitHub
      </a>
    </div>
  </div>
</section>

