---
import { i18n } from '../data/i18n';

const es = i18n.es.nav;
const en = i18n.en.nav;

const sections = ['about', 'experience', 'projects', 'skills', 'contact'] as const;
---

<nav
  id="site-nav"
  class="fixed top-0 inset-x-0 z-50 h-[60px] flex items-center justify-between section-x border-b border-transparent"
>
  <!-- Logo -->
  <button
    id="nav-logo"
    class="font-display font-bold text-[18px] tracking-[-0.04em] text-ink cursor-pointer bg-transparent border-none"
    aria-label="Volver al inicio"
  >
    R<span class="text-accent">.</span>L
  </button>

  <!-- Right side -->
  <div class="flex items-center gap-4">
    <!-- Nav links -->
    <div class="nav-links flex gap-[18px] text-sm font-medium text-ink2">
      {sections.map((key) => (
        <button
          data-section={key}
          class="nav-link cursor-pointer bg-transparent border-none text-ink2 hover:text-accent transition-colors duration-200 font-medium text-sm"
        >
          <span class="lang-es">{es[key]}</span>
          <span class="lang-en lang-hidden">{en[key]}</span>
        </button>
      ))}
    </div>

    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      aria-label="Cambiar tema"
      class="w-9 h-9 flex items-center justify-center rounded-full border border-edge text-ink2 hover:text-ink transition-[border-color,transform] duration-200 hover:border-ink3 cursor-pointer bg-transparent"
    >
      <!-- Sun (shown in dark mode) -->
      <svg
        id="icon-sun"
        class="hidden"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <!-- Moon (shown in light mode) -->
      <svg
        id="icon-moon"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- Language toggle -->
    <button
      id="lang-toggle"
      class="bg-ink text-page border-none rounded-full px-[14px] py-[5px] text-xs font-semibold tracking-wide cursor-pointer transition-[background-color,color] duration-300"
      aria-label="Switch language"
    >
      <span id="lang-label">EN</span>
    </button>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav')!;
  const logo = document.getElementById('nav-logo')!;
  const themeBtn = document.getElementById('theme-toggle')!;
  const iconSun = document.getElementById('icon-sun')!;
  const iconMoon = document.getElementById('icon-moon')!;
  const langBtn = document.getElementById('lang-toggle')!;
  const langLabel = document.getElementById('lang-label')!;

  // ── Scroll-based nav background ──────────────────────────────
  const handleScroll = () => {
    nav.classList.toggle('nav-scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // ── Smooth scroll to section ──────────────────────────────────
  const scrollTo = (id: string) => {
    const el = document.getElementById(id);
    if (!el) return;
    window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 72, behavior: 'smooth' });
  };

  logo.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  document.querySelectorAll<HTMLButtonElement>('[data-section]').forEach((btn) => {
    btn.addEventListener('click', () => scrollTo(btn.dataset.section!));
  });

  // ── Theme toggle ──────────────────────────────────────────────
  const isDark = () => document.documentElement.classList.contains('dark');

  const syncThemeIcons = () => {
    const dark = isDark();
    iconSun.classList.toggle('hidden', !dark);
    iconMoon.classList.toggle('hidden', dark);
  };

  themeBtn.addEventListener('click', () => {
    const dark = !isDark();
    document.documentElement.classList.toggle('dark', dark);
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    syncThemeIcons();
  });

  syncThemeIcons();

  // ── Language toggle ───────────────────────────────────────────
  const getSavedLang = () => (localStorage.getItem('lang') as 'es' | 'en') ?? 'es';

  const applyLang = (lang: 'es' | 'en') => {
    document.querySelectorAll('.lang-es').forEach((el) =>
      el.classList.toggle('lang-hidden', lang !== 'es'),
    );
    document.querySelectorAll('.lang-en').forEach((el) =>
      el.classList.toggle('lang-hidden', lang !== 'en'),
    );
    document.documentElement.lang = lang;
    langLabel.textContent = lang === 'es' ? 'EN' : 'ES';
    localStorage.setItem('lang', lang);
  };

  langBtn.addEventListener('click', () => {
    applyLang(getSavedLang() === 'es' ? 'en' : 'es');
  });

  // Apply saved language on load
  applyLang(getSavedLang());
</script>
